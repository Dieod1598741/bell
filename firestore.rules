rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 개발 단계: 모든 사용자가 읽기/쓰기 가능 (나중에 Firebase Auth 구현 시 변경 필요)
    match /users/{userId} {
      allow read, write: if true;
      
      // 채팅 알림 설정 서브컬렉션
      match /chat_notifications/{targetUserId} {
        allow read, write: if true;
      }
    }
    
    // 개발 단계: 모든 채팅 메시지 읽기/쓰기 가능
    match /chats/{messageId} {
      allow read, write: if true;
    }
    
    // 개발 단계: 모든 인박스 메시지 읽기/쓰기 가능
    match /inbox/{messageId} {
      allow read, write: if true;
    }
    
    // 개발 단계: 모든 메시지 읽기/쓰기 가능 (하위 호환성)
    match /messages/{messageId} {
      allow read, write: if true;
    }
    
    // 개발 단계: 모든 알림 읽기/쓰기 가능
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    
    // 개발 단계: 모든 알람 읽기/쓰기 가능
    match /announcements/{announcementId} {
      allow read, write: if true;
    }
    
    // 세션 관리 (백엔드가 프론트엔드 로그인 상태를 감지하기 위해)
    match /current_sessions/{sessionId} {
      allow read, write: if true;
    }
  }
}

